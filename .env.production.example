# ============================================================
# ARCHIVO DE EJEMPLO PARA PRODUCCIÓN EN EL VPS
# Copia este archivo como .env en el VPS (sin .example)
# Luego rellena TODOS los valores antes de lanzar Docker
# NUNCA hagas commit de un .env con contraseñas reales
# ============================================================

# --- Base de datos PostgreSQL ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CAMBIA_ESTO_POR_UNA_PASSWORD_SEGURA
POSTGRES_DB=torre_control_cyr

# --- Backend FastAPI ---
APP_ENV=production
# Genera tu SECRET_KEY con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CAMBIA_ESTO_POR_UNA_CLAVE_HEXADECIMAL_LARGA

# --- URL pública de tu dominio o IP del VPS ---
# Ejemplo con dominio:  https://torredcontrol.tuempresa.com
# Ejemplo con IP pura:  http://123.456.789.000
FRONTEND_URL=http://TU_IP_O_DOMINIO_AQUI
